# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit it.

# ── LLM (required for the custom LLM webhook) ─────────────────
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://api.mistral.ai/v1
LLM_MODEL=mistral-small-latest

# For AWS Bedrock, point BASE_URL at your CORS proxy or use boto3 directly:
# LLM_BASE_URL=https://bedrock-runtime.us-west-2.amazonaws.com/openai/v1
# LLM_MODEL=mistral.ministral-3-14b-instruct

# ── Image generation via fal.ai (optional) ────────────────────
FAL_API_KEY=your_fal_api_key_here
IMAGE_MODEL=fal-ai/flux/schnell
